PORT=3001
# Comma-separated list allowed.
# IMPORTANT: do NOT include a trailing slash. Example: https://myapp.vercel.app (not ...app/)
CORS_ORIGIN=https://ui-ux-project-7any.vercel.app
#
# Optional: allow preview domains via regex (example for Vercel previews)
# CORS_ORIGIN_REGEX=^https:\\/\\/.*\\.vercel\\.app$
# Render Postgres will provide this as an env var automatically.
# For local dev, set it to your local postgres connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foodbridge

