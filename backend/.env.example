PORT=3001
# Comma-separated list allowed (no spaces), e.g. http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN=http://localhost:5173

# Render Postgres will provide this as an env var automatically.
# For local dev, set it to your local postgres connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foodbridge

